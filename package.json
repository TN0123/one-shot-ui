{
  "name": "one-shot-ui",
  "version": "0.4.0",
  "description": "Deterministic UI extraction, diffing, and scaffolding from screenshots",
  "type": "module",
  "packageManager": "bun@1.3.2",
  "workspaces": [
    "packages/*"
  ],
  "bin": {
    "one-shot-ui": "dist/cli.mjs"
  },
  "files": [
    "dist/",
    "AGENTS.md",
    "skill/"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "ui",
    "screenshot",
    "extract",
    "diff",
    "scaffold",
    "design-to-code",
    "cli",
    "agent",
    "vision"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TN0123/one-shot-ui.git"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "prepublishOnly": "bun run build",
    "install:browsers": "playwright install chromium",
    "typecheck": "tsc --noEmit",
    "dev:extract": "bun packages/cli/src/index.ts extract",
    "dev:compare": "bun packages/cli/src/index.ts compare",
    "dev:capture": "bun packages/cli/src/index.ts capture",
    "dev:benchmark": "bun packages/cli/src/index.ts benchmark"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.54.2",
    "pngjs": "^7.0.0",
    "sharp": "^0.34.3",
    "tesseract.js": "^6.0.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "typescript": "^5.9.2"
  }
}
